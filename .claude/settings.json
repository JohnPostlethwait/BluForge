{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go vet *)",
      "Bash(go mod *)",
      "Bash(go run *)",
      "Bash(go get *)",
      "Bash(go install *)",
      "Bash(go generate *)",
      "Bash(templ generate *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch -a)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout -b *)",
      "Bash(git switch *)",
      "Bash(git stash)",
      "Bash(git stash list)",
      "Bash(git stash pop)",
      "Bash(git fetch *)",
      "Bash(docker build -t bluforge *)",
      "Bash(docker compose up *)",
      "Bash(docker compose build *)",
      "Bash(docker compose ps *)",
      "Bash(docker compose logs *)",
      "Bash(docker compose stop *)",
      "Bash(docker compose down)",
      "Bash(docker compose restart *)",
      "Bash(ls *)",
      "Bash(which *)",
      "Bash(mkdir *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git checkout -- *)",
      "Bash(git checkout . *)",
      "Bash(git restore *)",
      "Bash(git branch -D *)",
      "Bash(git branch -d *)",
      "Bash(git stash drop *)",
      "Bash(git stash clear *)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(docker compose down -v *)",
      "Bash(docker rm *)",
      "Bash(docker stop *)",
      "Bash(docker kill *)",
      "Bash(docker volume rm *)",
      "Bash(docker image rm *)",
      "Bash(docker image prune *)",
      "Bash(docker container rm *)",
      "Bash(docker container stop *)",
      "Bash(docker container kill *)",
      "Bash(docker system prune *)",
      "Read(.env)",
      "Read(.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)"
    ]
  }
}
